# Main Settings
GITLAB_CONTAINER_NAME=gitlab
GITLAB_PROTOCOL=http
GITLAB_HOST=gitlab.local
GITLAB_HTTP_PORT=80
GITLAB_SSH_PORT=2222
GITLAB_URL="${GITLAB_PROTOCOL}://${GITLAB_HOST}:${GITLAB_HTTP_PORT}"
GITLAB_URL_NO_PORT="${GITLAB_PROTOCOL}://${GITLAB_HOST}"

# Directories
GITLAB_BASE_DIR=D://GitLab
GITLAB_APP_DIR="${GITLAB_BASE_DIR}/App"
GITLAB_CONFIG_DIR="${GITLAB_APP_DIR}/config"
GITLAB_DATA_DIR="${GITLAB_APP_DIR}/data"
GITLAB_LOGS_DIR="${GITLAB_APP_DIR}/logs"
GITLAB_BACKUPS_DIR="${GITLAB_DATA_DIR}/backups"
GITLAB_SECRETS_DIR="${GITLAB_DATA_DIR}/gitlab-rails/etc"

# GitLab Runner
GITLAB_RUNNER_CONTAINER_NAME=gitlab-runner
GITLAB_RUNNER_DIR="${GITLAB_BASE_DIR}/Runner"
GITLAB_RUNNER_CONFIG_DIR="${GITLAB_RUNNER_DIR}/config"
GITLAB_RUNNER_CONFIG_FILE="${GITLAB_RUNNER_CONFIG_DIR}/config.toml"
GITLAB_RUNNER_DOCKER_IMAGE="node:20"

# Backup Settings
AUTO_BACKUP=false
BACKUP_BASE_DIR=X://MyPrograms/GitLab
BACKUP_APP_DIR="${BACKUP_BASE_DIR}/App"
BACKUP_CONFIG_DIR="${BACKUP_APP_DIR}/config"
BACKUP_DATA_DIR="${BACKUP_APP_DIR}/data"
BACKUP_BACKUPS_DIR="${BACKUP_DATA_DIR}/backups"
BACKUP_SECRETS_DIR="${BACKUP_DATA_DIR}/gitlab-rails/etc"
